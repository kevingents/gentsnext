# ── Database (verplicht) ─────────────────────────────────────────────────
# Komt automatisch binnen als je in Vercel onder Storage een Neon-database
# aan dit project koppelt. Lokaal: kopieer de connection string uit Vercel
# (Storage → Neon → .env.local tab) of uit de Neon-console.
DATABASE_URL=

# ── Cron-beveiliging (verplicht voor de cache-cron) ──────────────────────
# Vrij te kiezen geheim. Vercel stuurt dit automatisch als Bearer-token mee
# met cron-aanroepen zodra de env-var bestaat.
CRON_SECRET=

# ── Blob-store van storegents (voor de products-cache-publicatie) ────────
# Het BLOB_READ_WRITE_TOKEN van het STOREGENTS-Vercel-project, zodat de
# cache op shopify-products/cache.json in DIE store geschreven wordt
# (daar lezen de ~44 portal-modules hem). Zonder deze var valt de publisher
# terug op BLOB_READ_WRITE_TOKEN van dit project (alleen voor testen).
STOREGENTS_BLOB_READ_WRITE_TOKEN=

# ── Shopify (alleen nodig voor de eenmalige migratie-import) ─────────────
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-01
# Bootstrap-import: directe URL naar de bestaande cache-blob (optioneel,
# alternatief voor --file/--url op de command line).
STOREGENTS_PRODUCTS_CACHE_URL=

# ── Site ──────────────────────────────────────────────────────────────────
# Basis-URL voor productUrl's in de cache en (later) sitemap/canonicals.
PUBLIC_SITE_URL=https://gents.nl
# LAUNCH-SCHAKELAAR: pas op 'true' zetten bij de echte cutover van gents.nl.
# Zolang dit niet 'true' is, serveert de site robots.txt met disallow-all
# en noindex-metatags. Staat op de launch-checklist in de README.
SITE_INDEXABLE=false

# ── Sanity (content-CMS, /studio) ────────────────────────────────────────
# Maak gratis een project op sanity.io/manage. Project-ID + dataset publiek;
# token alleen voor de eenmalige seed (server-only).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# ── Sanity revalidate-webhook ───────────────────────────────────────────
# Zelfgekozen geheim; ook als "Secret" in de Sanity-webhook zetten.
SANITY_REVALIDATE_SECRET=
